BOT_TOKEN=your_telegram_bot_token

# Canonical engine shared with the website. Recommended in production.
BEAUTY_OS_API_URL=https://your-domain.ru/api/recommendations

# Local DeepSeek fallback if the shared engine is unavailable.
DEEPSEEK_API_KEY=your_deepseek_api_key
# Official DeepSeek: https://api.deepseek.com
# AI Tunnel: https://api.aitunnel.ru/v1
DEEPSEEK_API_BASE=
DEEPSEEK_MODEL=deepseek-chat

# Extra trusted official brand/retailer domains for direct-card verification.
PRODUCT_LINK_ALLOWED_HOSTS=
ADMIN_IDS=
